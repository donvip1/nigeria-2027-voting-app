# ========================================================
# Supabase public browser configuration
# ========================================================
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# ========================================================
# AdSense publisher client ID and optional ad unit slots
# ========================================================
VITE_ADSENSE_CLIENT=ca-pub-1294576989935252
VITE_ADSENSE_BANNER_SLOT=
VITE_ADSENSE_WIDE_SLOT=
VITE_ADSENSE_RECTANGLE_SLOT=

# ========================================================
# Optional anti-bot verification
# ========================================================
VITE_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
